# Copy to .env and fill in real values before running `docker compose up`.

# Postgres / backend DB password (used by both the postgres and backend services).
DB_PASSWORD=change-me

# Comma-separated list of origins allowed to call the backend API directly
# (CORS). Not needed for browser traffic through the frontend's nginx reverse
# proxy (same-origin), but Spring requires the property to be set regardless.
CORS_ALLOWED_ORIGINS=http://localhost:8081
